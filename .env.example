# Copia questo file in .env e compila i valori reali.
# Il file .env NON deve essere committato nel repository.

# ── Database ──────────────────────────────────────────────────────────────────
# SQL auth (user + password):
#   sqlserver://<user>:<password>@<host>:<port>?database=<db>&encrypt=true&trustservercertificate=true
DB_CONNECTION_STRING=sqlserver://user:password@localhost:1433?database=fixhistory&encrypt=true&trustservercertificate=true

# Windows Authentication: omit user/password and set windowsAuth: true in config.yaml
# (or pass --windows-auth on the command line). The driver will use SSPI on Windows.
# DB_CONNECTION_STRING=sqlserver://localhost:1433?database=fixhistory&encrypt=true&trustservercertificate=true

# ── Email ─────────────────────────────────────────────────────────────────────
# Indirizzo mittente visualizzato nel campo "From:"
EMAIL_FROM=cu-watcher@example.com

# Destinatario delle notifiche (un solo indirizzo; per più destinatari
# aggiungere più voci "to:" in config.yaml)
EMAIL_TO=admin@example.com

# Host SMTP (es. smtp.gmail.com, smtps.aruba.it)
EMAIL_SMTP_HOST=smtp.example.com

# Credenziali SMTP
EMAIL_USERNAME=your-smtp-username@example.com
EMAIL_PASSWORD=your-smtp-password
